# Copiar a .env.local (desarrollo) o a Vercel → Settings → Environment Variables (Production).
# Tras definirlas en Vercel, hacé Redeploy para que el servidor las cargue (NEXT_PUBLIC_* se bakea en el build).
#
# NEXT_PUBLIC_SITE_URL — Debe coincidir con el dominio primario en Vercel (https + host canónico, ej. www).
# Sirve para metadataBase, Open Graph absolutos, sitemap.xml y robots.txt.
# Producción recomendada: https://www.foundersclub.lat
# DNS en el registrador (hasta que apunte a Vercel, el dominio no cargará el sitio): A www → 76.76.21.21, A @ → 76.76.21.21, o nameservers ns1/ns2.vercel-dns.com
NEXT_PUBLIC_SITE_URL=https://www.foundersclub.lat
#
# Google Search Console (manual, tras deploy): añadí la propiedad del dominio → Inspección de URLs
# → pegá la URL canónica de inicio (ej. https://www.foundersclub.lat/) → "Solicitar indexación".
# En Sitemaps podés enviar: https://www.foundersclub.lat/sitemap.xml
#
# RESEND_API_KEY — Dashboard Resend → API Keys (empieza con re_)
# RESEND_FROM — ej. Clases <onboarding@resend.dev> o un remitente de dominio verificado
# RESEND_NOTIFY_TO — bandeja donde recibís los avisos (opcional; hay default en el código)

RESEND_API_KEY=
RESEND_FROM=
RESEND_NOTIFY_TO=

# ── Supabase (requerido para eventos: listado, admin, RSVP, sitemap con slugs) ──
# Sin SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY las APIs devuelven error service_unavailable (503).
# Supabase → Project Settings → API: Project URL y service_role (secreto, solo servidor).
# En Vercel: añadí ambas a Production y hacé Redeploy.
# Esquema: ejecutá una vez el SQL en supabase/events.sql (SQL Editor).
# Si ERROR 42703 en starts_at: otra tabla events previa; ver comentarios en events.sql o supabase/events_reset.sql.
# Si /events muestra error de carga: en Supabase Table Editor verificá que public.events tenga las columnas de supabase/events.sql (p. ej. starts_at, ends_at, is_published).
# La URL de este bloque debe ser el mismo proyecto Supabase donde mirás las tablas en el dashboard; si Vercel apunta a otro proyecto, la web no verá tus filas.
# Solo filas con is_published = true aparecen en /events; el admin muestra En vivo / Borrador.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Events module ──────────────────────────────────────────────────────
# EVENTS_ADMIN_PASSWORD — shared secret to access /events/admin (cookie-based session).
# En Vercel: asignala a Production (y Preview si usás previews). Sin comillas; evitá espacios al pegar.
# Verificación: el login de admin debe probarse en la URL de Production (ej. https://www.foundersclub.lat/events/admin),
# no en un deployment Preview (las env de Production no aplican ahí). Usá siempre https:// (la cookie es secure en prod).
# Tras crear o cambiar esta variable en Vercel, hacé Redeploy del entorno correspondiente para que el servidor la cargue.
EVENTS_ADMIN_PASSWORD=

# Stripe (optional — only needed for paid events)
# STRIPE_SECRET_KEY — sk_live_... or sk_test_...
# STRIPE_WEBHOOK_SECRET — whsec_... from Stripe dashboard → Webhooks
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY — pk_live_... or pk_test_...
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Vercel Cron — protects /api/cron/* endpoints (set automatically by Vercel, or add manually).
# Schedule in vercel.json is once daily (12:00 UTC) so it fits Vercel Hobby cron limits.
CRON_SECRET=
